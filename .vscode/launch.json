    "version": "0.2.0",
    "configurations": [

        {
            "name": "Detection",
            "type": "debugpy",
            "request": "launch",
            "program": "./YoloDetect",
            "console": "integratedTerminal",
            "sudo": true,
            "args": ["--task", "det,seg", "--german"]
        },
        {
            "name": "Pose Estimation",
            "type": "debugpy",
            "request": "launch",
            "program": "./YoloDetect",
            "console": "integratedTerminal",
            "sudo": true,
            "args": ["--stream", "--task", "pose"]
        },
        {
            "name": "Classification",
            "type": "debugpy",
            "request": "launch",
            "program": "./YoloDetect",
            "console": "integratedTerminal",
            "sudo": true,
            "args": ["--task", "cls"]
        }
    ]
}